// Control-loop flowchart as a snake (max 4 per row): row 1 left-to-right, row 2 right-to-left, with
// the "still draining" loop bowed out on the right through an invisible waypoint. Uniform box widths,
// even column spacing, compact row gap. Fixed positions, rendered with neato -n2. Standard
// UML/PlantUML palette (pale-yellow nodes, maroon borders, black start/stop).
// Render:  neato -n2 -Tpdf grace-convergence-activity.dot -o grace-convergence-activity.pdf
digraph control_loop {
  splines=line;
  node [shape=box, style="rounded,filled", fillcolor="#FEFECE", color="#A80036",
        fontname="Helvetica", fontsize=15, width=2.6, height=1.0, margin="0.16,0.11", penwidth=1.3];
  edge [fontname="Helvetica", fontsize=16, color="#A80036", fontcolor="#555555",
        penwidth=1.3, arrowsize=1.3];

  // Row 1 (left -> right): columns 260 pt apart; rows only 150 pt apart
  start  [shape=circle, label="", width=0.34, height=0.34, fixedsize=true, style=filled, fillcolor="#000000", color="#000000", pos="90,0!"];
  measure[label="Measure runtime state\n(backlog, handoff rate,\nconvergence time)", pos="230,0!"];
  size   [label="Compute grace period\nand rollout pace",                            pos="490,0!"];
  drain  [label="SIGTERM:\ndrain and hand off state",                                pos="750,0!"];

  // Row 2 (right -> left)
  decide [shape=diamond, width=2.5, height=1.4, label="handoff\ncomplete?",          pos="750,-150!"];
  done   [label="Clean shutdown\n(before SIGKILL)",                                  pos="490,-150!"];
  stop   [shape=doublecircle, label="", width=0.34, height=0.34, fixedsize=true, style=filled, fillcolor="#000000", color="#000000", pos="330,-150!"];

  start -> measure;
  measure -> size;
  size -> drain;
  drain -> decide;                                    // snake turn (down)
  decide -> done [label="  yes"];
  done -> stop;

  // "no" loop: clean right-angle path on the right (straight segments via two corner waypoints)
  wpA [shape=point, width=0.01, height=0.01, style=invis, pos="910,-150!"];
  wpB [shape=point, width=0.01, height=0.01, style=invis, pos="910,0!"];
  decide -> wpA [arrowhead=none, tailport=e, constraint=false];
  wpA -> wpB [arrowhead=none, label="no (still draining)", constraint=false];
  wpB -> drain [headport=e, constraint=false];
}
